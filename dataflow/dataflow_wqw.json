				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'src_object',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source17",
				"source1 select(mapColumn(",
				"          PersonID,",
				"          Name,",
				"          LastModifytime",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source2 filter(type == 'P') ~> filter1",
				"source3 split(type_desc == 'USER_TABLE' || type_desc == 'VIEW',",
				"     type_desc == 'SQL_STORED_PROCEDURE'|| type_desc == 'SQL_SCALAR_FUNCTION',",
				"     disjoint: false) ~> split1@(typeTableView, typeProgramObject, typeOther)",
				"source4 select(mapColumn(",
				"          body,",
				"          headers,",
				"          each(body.results,match(true()))",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"source5, source6, source7 union(byName: true)~> union1",
				"source8, source9 exists(source8@name==source9@name,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists1",
				"source10 sort(asc(name, true),",
				"     caseInsensitive: true) ~> sort1",
				"source11 aggregate(cnt = count(object_id),",
				"          each(match(type=='string'&&name!='type'&&name!='type_desc'), $$ = count(object_id)),",
				"          each(match(in(['type','type_desc'],name)), $$ = first($$))) ~> aggregate1",
				"select2 alterRow(insertIf(1==1)) ~> www",
				"source12, source13 join(fuzzyCompare(source12@name, source13@name, 80.00),",
				"     joinType:'inner',",
				"     matchType:'fuzzy',",
				"     ignoreSpaces: true,",
				"     broadcast: 'off')~> join1",
				"join1 select(mapColumn(",
				"          each(match(instr(name,'soucre12@')==0))",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"source14 pivot(groupBy(name),",
				"     pivotBy(class, ['语文', '数学', '英语']),",
				"     sum = sum(score),",
				"     columnNaming: 'a$Nb$Vc',",
				"     lateral: true) ~> pivot1",
				"source15, source16 lookup(source15@name == source16@name,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 select(mapColumn(",
				"          each(match(instr(name,'source15@')==0))",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"source17 derive(column1 = 'a column value',",
				"          each(match(type=='integer'), $$ = $$ + 2),",
				"          each(match(type=='string'), $$ = $$+ 'kk'),",
				"          each(match(type=='string'), $$+'short' = $$+'123'),",
				"          column2 = 'adadas') ~> derivedColumn1",
