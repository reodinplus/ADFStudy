				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'src_object',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source11",
				"source(output(",
				"          name as string,",
				"          object_id as integer,",
				"          principal_id as integer,",
				"          schema_id as integer,",
				"          parent_object_id as integer,",
				"          type as string,",
