				"source2, source3 exists(source2@id==source3@id,",
				"     negate:true,",
				"     broadcast: 'right')~> exists1",
				"source4 filter(length(name)>4) ~> filter1",
				"source5 split(id<3,",
				"     id>4,",
				"     disjoint: false) ~> split1@(id3, id4, other)",
				"source6, source7 union(byName: true)~> union1",
				"source8 sort(asc(name, true)) ~> sort1",
				"source9, source10 join(source9@id == source10@id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'right')~> join1",
				"source11 pivot(groupBy(name),",
				"     pivotBy(class, ['语文', '数学', '英语']),",
				"     {} = sum(score),",
				"     columnNaming: '$N$V',",
				"     lateral: true) ~> pivot1",
				"source12, source13 lookup(source12@id != source13@id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'right')~> lookup1",
				"source14 keyGenerate(output(newid as long),",
				"     startAt: 1L,",
				"     stepValue: 2L) ~> surrogateKey1",
				"source15 cast(output(",
