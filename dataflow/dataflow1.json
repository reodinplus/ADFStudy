				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"source14 derive(each(match(type=='integer'), $$ = $$+2),",
				"          each(match(type=='string'), 'add' = $$+'ad')) ~> derivedColumn1",
