				"     {} = sum(sorce),",
				"     columnNaming: '$N$V',",
				"     lateral: false) ~> pivot1",
				"source12, source13 lookup(source12@Name == source13@Name,",
				"     multiple: true,",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 select(mapColumn(",
				"          PersonID = source12@PersonID,",
				"          Name = source12@Name,",
				"          LastModifytime = source12@LastModifytime,",
				"          PersonID = source13@PersonID,",
