				"source2 filter(PersonID == 7 || PersonID == 6) ~> filter1",
				"source3 split(PersonID ==6 || PersonID==7,",
				"     Name=='aaaa',",
				"     disjoint: true) ~> split@(splitId, splitName, Other)",
				"source4, source5 union(byName: true)~> union1",
				"source6, source7 exists(source6@Name==source7@Name,",
				"     negate:false,",
