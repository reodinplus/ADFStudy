				"aggregate1 sort(desc(PersonID, true)) ~> sort1",
				"source8 aggregate(groupBy(PersonID),",
				"     each(match(type=='string'), 'cnt' = count(Name))) ~> aggregate1",
				"source9, source10 join(source9@Name == source10@Name,",
				"     joinType:'outer',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 select(mapColumn(",
