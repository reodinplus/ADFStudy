{
	"name": "dataflow_derivedcolumn_cjw",
	"properties": {
		"folder": {
			"name": "dataflow_cjw"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "adfdemo_asql_src_cjw",
						"type": "LinkedServiceReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "adfdemo_asql_dst_cjw",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          name as string,",
				"          object_id as integer,",
				"          principal_id as integer,",
				"          schema_id as integer,",
				"          parent_object_id as integer,",
				"          type as string,",
				"          type_desc as string,",
				"          create_date as timestamp,",
				"          modify_date as timestamp,",
				"          is_ms_shipped as boolean,",
				"          is_published as boolean,",
				"          is_schema_published as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'src_adfdemo_object_cjw',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source1",
				"source1 derive({列1} = 111,",
				"          each(match(type=='integer'), $$ = $$+2),",
				"          each(match(type=='string'), $$ = $$+'kk')) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'stg_adfdemo_object_cjw',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}