			"scriptLines": [
				"source(output(",
				"          Id as string,",
				"          Name as string,",
				"          Age as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT \\'1\\' AS Id, \\'Jone\\' AS [Name] ,25 AS [Age]\\nUNION ALL \\nSELECT \\'2\\' AS Id, \\'Zoe\\' AS [Name] ,22 AS [Age]',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source1",
				"source(output(",
				"          Id as string,",
				"          Name as string,",
				"          Age as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT \\'3\\' AS Id, \\'Kittey\\' AS [Name] ,15 AS [Age]\\nUNION ALL \\nSELECT \\'4\\' AS Id, \\'Aqua\\' AS [Name] ,29 AS [Age]',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source2",
				"source(output(",
				"          Name as string,",
				"          city as string,",
				"          code as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',\\'NewYork\\',\\'178000\\'),\\n(\\'Aqua\\',\\'London\\',\\'265489\\'))\\nt1 ([Name],city,code)\\n',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source3",
				"source(output(",
				"          Name as string,",
				"          Score as integer,",
				"          Class as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',74,\\'Math\\'),\\n(\\'Mea\\',84,\\'English\\'),\\n(\\'Aqua\\',56,\\'Math\\'),\\n(\\'Aqua\\',25,\\'English\\'))\\nt1 ([Name],Score,Class)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source4",
				"source(output(",
				"          Name as string,",
				"          Score as integer,",
				"          Class as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',74,\\'Math\\'),\\n(\\'Mea\\',84,\\'English\\'),\\n(\\'Aqua\\',56,\\'Math\\'),\\n(\\'Aqua\\',25,\\'English\\'))\\nt1 ([Name],Score,Class)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source5",
				"source(output(",
				"          Id as string,",
				"          Name as string,",
				"          Age as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'Customer_fzx',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source6",
				"source(output(",
				"          Name as string,",
				"          Score as integer,",
				"          Class as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',74,\\'Math\\'),\\n(\\'Mea\\',84,\\'English\\'),\\n(\\'Aqua\\',56,\\'Math\\'),\\n(\\'Aqua\\',25,\\'English\\'))\\nt1 ([Name],Score,Class)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source8",
				"source(output(",
				"          Name as string,",
				"          city as string,",
				"          code as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',\\'NewYork\\',\\'178000\\'),\\n(\\'Aqua\\',\\'London\\',\\'265489\\'))\\nt1 ([Name],city,code)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source9",
				"source(output(",
				"          Name as string,",
				"          Score as integer,",
				"          Class as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',74,\\'Math\\'),\\n(\\'Mea\\',84,\\'English\\'),\\n(\\'Aqua\\',56,\\'Math\\'),\\n(\\'Aqua\\',25,\\'English\\'))\\nt1 ([Name],Score,Class)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source10",
				"source(output(",
				"          Name as string,",
				"          Score as integer,",
				"          Class as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',74,\\'Math\\'),\\n(\\'Mea\\',84,\\'English\\'),\\n(\\'Aqua\\',56,\\'Math\\'),\\n(\\'Aqua\\',25,\\'English\\'))\\nt1 ([Name],Score,Class)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source11",
				"source(output(",
				"          Name as string,",
				"          Class as string,",
				"          Score as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',\\'Class1\\',95),\\n(\\'Tamaki\\',\\'Class1\\',98),\\n(\\'Aqua\\',\\'Class1\\',54),\\n(\\'Rushia\\',\\'Class2\\',98),\\n(\\'Ayame\\',\\'Class2\\',89),\\n(\\'Alice\\',\\'Class1\\',65)\\n)\\nt1 ([Name],[Class],Score)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source12",
				"source(output(",
				"          Name as string,",
				"          Class as string,",
				"          Score as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',\\'Class1\\',95),\\n(\\'Tamaki\\',\\'Class1\\',98),\\n(\\'Aqua\\',\\'Class1\\',54),\\n(\\'Rushia\\',\\'Class2\\',98),\\n(\\'Ayame\\',\\'Class2\\',89),\\n(\\'Alice\\',\\'Class1\\',65)\\n)\\nt1 ([Name],[Class],Score)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source13",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM  \\n(Values\\n(\\'Mea\\',\\'NewYork\\',\\'178000\\'),\\n(\\'Aqua\\',\\'London\\',\\'265489\\'))\\nt1 ([Name],city,code)',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source14",
				"source1, source2 union(byName: true)~> union1",
				"source3, source4 join(source3@Name == source4@Name,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"source5 pivot(groupBy(Name),",
				"     pivotBy(Class, ['English', 'Math']),",
				"     Score = sum(Score),",
				"     columnNaming: '$V$N',",
				"     lateral: true) ~> pivot1",
				"source6 select(mapColumn(",
				"          Id,",
				"          Name,",
				"          Age",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"pivot1 derive(TotalScore = EnglishScore + MathScore) ~> derivedColumn1",
				"source8, source9 lookup(source8@Name == source9@Name,",
				"     multiple: false,",
				"     pickup: 'first',",
				"     asc(code, true),",
				"     broadcast: 'auto')~> lookup1",
				"select2 aggregate(groupBy(Name),",
				"     TotalScore = sum(Score)) ~> aggregate1",
				"source10 select(mapColumn(",
				"          Name,",
				"          Score",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"source11 split(greater(Score,80),",
				"     disjoint: false) ~> split1@(Good, Bad)",
				"source12 window(over(Class),",
				"     desc(Score, true),",
				"     Rank = denseRank()) ~> window1",
				"source13, source14 exists(in(['Class1','Class3'],Class),",
				"     negate:false,",
				"     broadcast: 'auto')~> exists1",
				"union1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'Customer_fzx',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 0,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"join1 sink(validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     store: 'cache',",
				"     format: 'inline',",
				"     output: false,",
				"     saveOrder: 1) ~> sink2",
				"derivedColumn1 sink(validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     store: 'cache',",
				"     format: 'inline',",
				"     output: false,",
				"     saveOrder: 1) ~> sink3",
				"select1 sink(validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     store: 'cache',",
				"     format: 'inline',",
				"     output: false,",
				"     saveOrder: 1) ~> sink4",
				"aggregate1 sink(validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     store: 'cache',",
				"     format: 'inline',",
				"     output: false,",
				"     saveOrder: 1) ~> sink5",
				"split1@Good sink(validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     store: 'cache',",
				"     format: 'inline',",
				"     output: false,",
				"     saveOrder: 1) ~> sink6",
				"split1@Bad sink(validateSchema: false,",
