				"name": "性别",
				"type": "String"
			},
			{
				"name": "年龄",
				"type": "String"
			},
			{
				"name": "细分",
				"type": "String"
			},
			{
				"name": "职业",
				"type": "String"
			},
			{
				"name": "行业",
				"type": "String"
			}
		]
	},
	"type": "Microsoft.DataFactory/factories/datasets"
