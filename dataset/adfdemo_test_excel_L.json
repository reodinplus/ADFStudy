			"referenceName": "adfdemo_storage",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"blob": {
				"type": "string",
				"defaultValue": "adfdemo"
			},
			"dicretory": {
				"type": "string",
				"defaultValue": "xsalex/customdata/success"
			},
			"tablename": {
				"type": "string",
				"defaultValue": "客户数据.xlsx"
			},
			"Sheet": {
				"type": "string",
				"defaultValue": "Sheet1"
			}
		},
		"folder": {
