{
	"name": "pipeline_contral_flow",
	"properties": {
		"activities": [
			{
				"name": "Filter AnimalArray",
				"type": "Filter",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@variables('AnimalArray')",
						"type": "Expression"
					},
					"condition": {
						"value": "@equals(item(),'Cat')",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Filter intarray",
				"type": "Filter",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@variables('IntArray')",
						"type": "Expression"
					},
					"condition": {
						"value": "@greater(item(),3 )",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Filter nameArray",
				"type": "Filter",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@variables('NameArray')",
						"type": "Expression"
					},
					"condition": {
						"value": "@greater(int(item().value),3 )",
						"type": "Expression"
					}
				}
			},
			{
				"name": "ForEach1",
				"type": "ForEach",
				"dependsOn": [
