															"type": "String",
															"physicalType": "String"
														},
														"sink": {
															"name": "price",
															"type": "Decimal",
															"physicalType": "decimal",
															"scale": 0,
															"precision": 18
														}
													},
													{
														"source": {
															"name": "subtotal",
															"type": "String",
															"physicalType": "String"
														},
														"sink": {
															"name": "subtotal",
															"type": "Decimal",
															"physicalType": "decimal",
															"scale": 0,
															"precision": 18
														}
													}
												],
												"typeConversion": true,
												"typeConversionSettings": {
													"allowDataTruncation": true,
													"treatBooleanAsNumber": false
												}
