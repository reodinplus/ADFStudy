													"useTempDB": false,
													"keys": [
														"productId"
													],
													"interimSchemaName": "dbo"
												},
												"sqlWriterUseTableLock": false,
												"disableMetricsCollection": false
											},
											"enableStaging": false,
											"translator": {
												"type": "TabularTranslator",
												"mappings": [
													{
														"source": {
															"name": "file_name",
															"type": "String"
														},
														"sink": {
															"name": "file_name",
															"type": "String",
															"physicalType": "nvarchar"
														}
													},
													{
														"source": {
															"name": "file_last_modify_time",
															"type": "String"
														},
														"sink": {
															"name": "file_last_modify_time",
															"type": "DateTime",
															"physicalType": "datetime"
														}
													},
													{
														"source": {
															"name": "productId",
															"type": "String",
															"physicalType": "String"
														},
														"sink": {
															"name": "productId",
															"type": "Int32",
															"physicalType": "int"
														}
													},
													{
														"source": {
															"name": "qty",
															"type": "String",
															"physicalType": "String"
														},
														"sink": {
															"name": "qty",
															"type": "Int32",
															"physicalType": "int"
														}
													},
													{
														"source": {
