				"type": "string",
				"defaultValue": "Sales_fzx/test_sales_fzx"
			},
			"SchemaName": {
				"type": "string",
				"defaultValue": "dbo"
			},
			"TableName": {
				"type": "string",
				"defaultValue": "adfdemo_stg_sales"
			},
			"ContainName": {
				"type": "string",
				"defaultValue": "adfdemo"
			},
			"FlieType": {
