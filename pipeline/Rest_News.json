{
	"name": "Rest_News",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [
					{
						"name": "Source",
						"value": "/api/news"
					},
					{
						"name": "Destination",
						"value": "@{'dbo'}.@{pipeline().parameters.table}"
					}
				],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"supportRFC5988": "true"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "['id']"
								},
								"sink": {
									"name": "id",
									"type": "Int32"
								}
							},
							{
								"source": {
									"path": "['title']"
								},
								"sink": {
									"name": "title",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "['source']"
								},
								"sink": {
									"name": "source",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "['cmtcount']"
								},
								"sink": {
									"name": "cmtcount",
									"type": "Int32"
								}
							},
							{
								"source": {
									"path": "['img']"
								},
								"sink": {
									"name": "img",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "['time']"
								},
								"sink": {
									"name": "time",
									"type": "DateTime"
								}
							}
						],
						"collectionReference": "$['data']",
						"mapComplexValuesToString": true
					}
				},
				"inputs": [
					{
						"referenceName": "RestResource_News",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "AzureSqlTable",
						"type": "DatasetReference",
						"parameters": {
							"table": {
								"value": "@pipeline().parameters.table",
								"type": "Expression"
							},
							"schema": "dbo"
						}
					}
				]
			}
		],
		"parameters": {
			"table": {
				"type": "string",
				"defaultValue": "RestService_News"
			}
		},
		"folder": {
			"name": "pipeline_jbl"
		},
		"annotations": [],
		"lastPublishTime": "2024-09-27T02:11:27Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}