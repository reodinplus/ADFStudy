										},
										"TableName": {
											"value": "@item().TableName",
											"type": "Expression"
										},
										"HostName": {
											"value": "@pipeline().parameters.HostName",
											"type": "Expression"
										},
										"dbName": {
											"value": "@pipeline().parameters.DBName",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			}
		],
