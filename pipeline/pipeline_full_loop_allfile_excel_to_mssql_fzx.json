						"parameters": {
							"SchemaName": " ",
							"TableName": " "
						}
					},
					"firstRowOnly": false
				}
			},
			{
				"name": "ForEach_TableList",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "Get_Table_List",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
