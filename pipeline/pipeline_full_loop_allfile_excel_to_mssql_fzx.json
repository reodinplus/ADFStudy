				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT 'STG_Sales_Product' AS TableName, N'产品数据' AS FolderName\nUNION ALL\nSELECT 'STG_Sales_Order' AS TableName, N'订单数据' AS FolderName\nUNION ALL\nSELECT 'STG_Sales_Area' AS TableName, N'地点数据' AS FolderName\nUNION ALL\nSELECT 'STG_Sales_Customer' AS TableName, N'客户数据' AS FolderName",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "adf_asql_dataset_fzx",
