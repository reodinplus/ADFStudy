{
	"name": "adfdemo_to_asql",
	"type": "Microsoft.DataFactory/factories/linkedservices",
	"properties": {
		"parameters": {
			"servername": {
				"type": "string",
				"defaultValue": "azuresqlstxserver.database.windows.net"
			},
			"dbname": {
				"type": "string",
				"defaultValue": "adfstudy"
			},
			"username": {
				"type": "string",
				"defaultValue": "cdstx"
			},
			"pwd": {
				"type": "string",
				"defaultValue": "1qaz!QAZ"
			}
		},
		"annotations": [],
		"type": "AzureSqlDatabase",
		"typeProperties": {
			"connectionString": "Integrated Security=False;Encrypt=True;Connection Timeout=30;Data Source=@{linkedService().servername};Initial Catalog=@{linkedService().dbname};User ID=@{linkedService().username};Password=@{linkedService().pwd}"
		}
	}
}